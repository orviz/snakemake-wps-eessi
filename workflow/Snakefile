import os

# Load the user-defined configuration file
configfile: "config/config.yaml"

# Retrieve pipeline parameters from the configuration file
EESSI_INIT = config.get("eessi_init_script", "/cvmfs/software.eessi.io/versions/latest/init/bash")
WPS_EB_CONFIG = config.get("wps_easyconfig_path", "config/WPS-4.6.0-custom.eb")
WPS_GIT_REPO = config.get("wps_git_repo", "https://github.com")
WPS_GIT_VERSION = config.get("wps_git_version", "v4.6.0")

rule all:
    input:
        "bin/wps_compilation.done"

# =========================================================================
# RULE: COMPILE WPS VIA EESSI & EASYBUILD (GIT DRIVEN)
# =========================================================================
# This rule triggers EasyBuild on the HPC cluster using the EESSI stack.
# It injects the targeted Git repository and version tag from the config
# straight into the EasyConfig builder environment.
# =========================================================================
rule compile_wps_hpc:
    input:
        # Track the EasyConfig recipe file. If the recipe changes, recompile.
        eb_recipe = WPS_EB_CONFIG
    output:
        marker = "bin/wps_compilation.done"
    shell:
        """
        echo "[Snakemake] Targeting HPC Environment via EESSI..."

        # 1. Initialize EESSI stack via the parameterized initialization script
        set +u
        if [ -f "{EESSI_INIT}" ]; then
            source {EESSI_INIT}
        else
            echo "[Snakemake Error] EESSI initialization script not found at: {EESSI_INIT}"
            exit 1
        fi
        
        # 2. Load the official extension tool which safely configures EasyBuild on top of EESSI
        module load EESSI-extend
        set -u

        # 3. Export Git parameters into the environment for EasyBuild to read them
        export WPS_GIT_REPO="{WPS_GIT_REPO}"
        export WPS_GIT_VERSION="{WPS_GIT_VERSION}"

        echo "[Snakemake] Building WPS from Repo: $WPS_GIT_REPO ($WPS_GIT_VERSION)"
        
        # 4. Invoke EasyBuild. It will natively clone the code and handle all dependencies
        eb {input.eb_recipe} --robot

        # Generate the execution proof marker token to let Snakemake satisfy downstream dependencies
        mkdir -p $(dirname {output.marker})
        touch {output.marker}
        """
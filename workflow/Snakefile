# workflow/Snakefile
import os
import hashlib

configfile: "config/config.yaml"

# --- 1. VALIDACIÓN ESTRICTA ---
required_keys = ["wps_git_repo", "wps_version", "wps_git_sha256", "eessi_init_script"]
for key in required_keys:
    if key not in config or not config[key]:
        raise KeyError(f"\n❌ [Snakemake Error]: Falta '{key}' en config.yaml.\n")

WPS_REPO    = config["wps_git_repo"]
WPS_VERSION = config["wps_version"]  
WPS_SHA256  = config["wps_git_sha256"]
EESSI_INIT  = config["eessi_init_script"]

rule all:
    input:
        "bin/wps_compilation.done"

# =========================================================================
# REGLA ÚNICA: Control de ciclo de vida desacoplado mediante script
# =========================================================================
rule compile_wps_hpc:
    output:
        tarball = f"sources/WPS-{WPS_VERSION}.tar.gz",
        marker  = "bin/wps_compilation.done"
    params:
        url        = f"{WPS_REPO}/archive/refs/tags/{WPS_VERSION}.tar.gz",
        sha256     = WPS_SHA256,
        target_dir = os.path.abspath(f"software/WPS-{WPS_VERSION}"),
        marker_abs = os.path.abspath("bin/wps_compilation.done"),
        marker_dir = os.path.abspath("bin"),
        eessi_init = EESSI_INIT
    threads: 8
    run:
        # --- ETAPA A: DESCARGA NATIVA ---
        print(f"[Snakemake] Downloading official Tarball upstream: {params.url}")
        os.makedirs("sources", exist_ok=True)
        shell(f"wget -q -O {output.tarball} {params.url}")
        
        # --- ETAPA B: VALIDACIÓN ESTRICTA SHA256 DE SEGURIDAD ---
        print("[Snakemake] Verifying SHA256 checksum...")
        sha256_hash = hashlib.sha256()
        with open(output.tarball, "rb") as f:
            for byte_block in iter(lambda: f.read(4096), b""):
                sha256_hash.update(byte_block)
        computed_sha = sha256_hash.hexdigest()
        
        if computed_sha != params.sha256:
            raise ValueError(f"\n❌ [Security Error]: Checksum Mismatch!\n")
        print(" [OK] Checksum verified successfully!")
        
        # --- ETAPA C: DESCOMPRESIÓN Y DELEGACIÓN EN SCRIPT ---
        print(f"[Snakemake] Unpacking source code into local environment...")
        os.makedirs(params.target_dir, exist_ok=True)
        shell(f"tar -xzf {output.tarball} --strip-components=1 -C {params.target_dir}")
        
        print("[Snakemake] Launching decoupled compilation script...")
        shell(f"workflow/compile_wps.sh '{params.eessi_init}' '{params.target_dir}' '{params.marker_dir}' '{params.marker_abs}'")
